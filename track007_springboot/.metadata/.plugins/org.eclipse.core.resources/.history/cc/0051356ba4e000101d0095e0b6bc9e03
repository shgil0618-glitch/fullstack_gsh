<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org"
      xmlns:layout="http://www.ultraq.net.nz/thymeleaf/layout"
      layout:decorate="~{fragments/layout}">
<head lang="ko">
  <meta charset="UTF-8">
  <title>레시피 등록</title>
</head>

<body>
<div layout:fragment="content" class="container mt-5">
  <h3>새 레시피 작성</h3>

  <form th:action="@{/recipes/register}"
        method="post"
        enctype="multipart/form-data">

    <input type="hidden" th:name="${_csrf.parameterName}"
           th:value="${_csrf.token}"/>

    <!-- 제목 -->
    <div class="mb-3">
      <label class="form-label">레시피 제목 *</label>
      <input type="text" class="form-control"
             name="title" required>
    </div>

    <!-- 카테고리 / 난이도 -->
    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label">카테고리 *</label>
        <select name="category" class="form-select" required>
          <option value="">선택</option>
          <option value="2">한식</option>
          <option value="3">양식</option>
          <option value="4">중식</option>
          <option value="5">일식</option>
          <option value="6">디저트</option>
        </select>
      </div>

      <div class="col-md-6 mb-3">
        <label class="form-label">난이도 *</label>
        <select name="difficulty" class="form-select" required>
          <option value="쉬움">쉬움</option>
          <option value="보통" selected>보통</option>
          <option value="어려움">어려움</option>
        </select>
      </div>
    </div>

    <!-- 시간 / 인분 -->
    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label">조리 시간(분)</label>
        <input type="number" class="form-control"
               name="cookTime" value="30" required>
      </div>
      <div class="col-md-6 mb-3">
        <label class="form-label">인분</label>
        <input type="number" class="form-control"
               name="servings" value="2" required>
      </div>
    </div>

    <!-- 대표 이미지 -->
    <div class="mb-3">
      <label class="form-label">대표 이미지</label>
      <input type="file" class="form-control"
             name="imageFile" required>
    </div>

    <!-- 설명 -->
    <div class="mb-3">
      <label class="form-label">레시피 설명 *</label>
      <textarea class="form-control"
                name="description"
                rows="3" required></textarea>
    </div>

    <!-- 재료 -->
    <div class="mb-3">
      <div class="d-flex justify-content-between">
        <label class="form-label">재료 *</label>
        <button type="button"
                class="btn btn-sm btn-outline-primary"
                id="addIngredientBtn">+ 재료 추가</button>
      </div>

      <div id="ingredientsContainer">
        <div class="row g-2 mb-2 ingredient-row">
          <div class="col-5">
            <input type="text" class="form-control"
                   name="ingredients"
                   placeholder="재료명" required>
          </div>
          <div class="col-5">
            <input type="text" class="form-control"
                   name="ingreNums"
                   placeholder="양" required>
          </div>
          <div class="col-2 d-grid">
            <button type="button"
                    class="btn btn-danger btn-remove-ingre">
              삭제
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- 조리 단계 -->
    <div class="mb-3">
      <div class="d-flex justify-content-between">
        <label class="form-label">조리 방법 *</label>
        <button type="button"
                class="btn btn-sm btn-outline-primary"
                id="addStepBtn">+ 단계 추가</button>
      </div>

      <div id="stepsContainer">
        <div class="card p-3 mb-2 step-row">
          <textarea class="form-control mb-2"
                    name="steps"
                    rows="2"
                    placeholder="조리 단계 설명"
                    required></textarea>
          <input type="file"
                 name="stepImages"
                 class="form-control">
          <button type="button"
                  class="btn btn-sm btn-danger mt-2 btn-remove-step">
            단계 삭제
          </button>
        </div>
      </div>
    </div>

    <!-- URL -->
    <div class="mb-3">
      <label class="form-label">레시피 URL</label>
      <input type="text" class="form-control"
             name="rUrl">
    </div>

    <input type="hidden" name="status" value="PUBLIC">

    <!-- 버튼 -->
    <div class="text-end">
      <button type="submit" class="btn btn-warning">
        레시피 등록
      </button>
    </div>
  </form>

  <!-- JS -->
  <script>
    const ingreBox = document.getElementById('ingredientsContainer');
    const stepBox = document.getElementById('stepsContainer');

    document.getElementById('addIngredientBtn').onclick = () => {
      const div = document.createElement('div');
      div.className = 'row g-2 mb-2 ingredient-row';
      div.innerHTML = `
        <div class="col-5">
          <input class="form-control" name="ingredients" required>
        </div>
        <div class="col-5">
          <input class="form-control" name="ingreNums" required>
        </div>
        <div class="col-2 d-grid">
          <button type="button"
                  class="btn btn-danger btn-remove-ingre">삭제</button>
        </div>`;
      ingreBox.appendChild(div);
    };

    ingreBox.onclick = e => {
      if (e.target.classList.contains('btn-remove-ingre')) {
        e.target.closest('.ingredient-row').remove();
      }
    };

    document.getElementById('addStepBtn').onclick = () => {
      const div = document.createElement('div');
      div.className = 'card p-3 mb-2 step-row';
      div.innerHTML = `
        <textarea class="form-control mb-2"
                  name="steps"
                  rows="2" required></textarea>
        <input type="file"
               name="stepImages"
               class="form-control">
        <button type="button"
                class="btn btn-sm btn-danger mt-2 btn-remove-step">
          단계 삭제
        </button>`;
      stepBox.appendChild(div);
    };

    stepBox.onclick = e => {
      if (e.target.classList.contains('btn-remove-step')) {
        e.target.closest('.step-row').remove();
      }
    };
  </script>

</div>
</body>
</html>
