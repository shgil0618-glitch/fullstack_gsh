<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org"
	xmlns:layout="http://www.ultraq.net.nz/thymeleaf/layout"
	layout:decorate="~{fragments/layout}">
<head>
<meta charset="UTF-8">
<title>레시피 상세</title>
</head>

<body>
	<div layout:fragment="content" class="container mt-5">

		<!-- 제목 -->
		<h2 th:text="${recipe.title}">레시피 제목</h2>

		<!-- 대표 이미지 -->
		<div class="mb-3" th:if="${recipe.image != null}">
			<img th:src="@{/upload/{img}(img=${recipe.image})}"
				style="max-width: 300px;">
		</div>

		<!-- 기본 정보 -->
		<p>
			<strong>카테고리:</strong> <span th:if="${recipe.categoryName != null}"
				th:text="${recipe.categoryName}"></span> <span
				th:if="${recipe.categoryName == null}"> 미분류 </span>
		</p>

		<p>
			<strong>작성자:</strong> <span th:text="${recipe.appUserId}"></span>
		</p>

		<p>
			<strong>조회수:</strong> <span th:text="${recipe.views}"></span>
		</p>

		<hr>

		<!-- 설명 -->
		<div>
			<h4>설명</h4>
			<p th:text="${recipe.description}"></p>
		</div>

		<hr>

		<!-- 재료 -->
		<div>
			<h4>재료</h4>

<ul th:if="${ingredients != null and ingredients.size() > 0}">
  <li th:each="ing : ${ingredients}"
      th:if="${ing != null}">
    <span th:text="${ing.ingreName != null ? ing.ingreName : ''}"></span>
    <span th:if="${ing.ingreNum != null}">
      -
      <span th:text="${ing.ingreNum}"></span>
    </span>
  </li>
</ul>

<p th:if="${ingredients == null or ingredients.size() == 0}">
  등록된 재료가 없습니다.
</p>

		</div>

		<hr>

		<!-- 조리 단계 -->
		<div>
			<h4>조리 단계</h4>

			<div th:if="${steps != null and steps.size() > 0}">
				<div th:each="st, iter : ${steps}" class="mb-3">
					<p>
						<strong th:text="${iter.index + 1}"></strong>. <span
							th:text="${st.stepDesc != null ? st.stepDesc : ''}"></span>
					</p>

					<img th:if="${st.stepImage != null}"
						th:src="@{/upload/{img}(img=${st.stepImage})}"
						style="max-width: 200px;">
				</div>
			</div>

			<p th:if="${steps == null or steps.size() == 0}">등록된 조리 단계가 없습니다.
			</p>

		</div>

		<hr>

		<!-- 버튼 -->
		<div class="mt-4">
			<a th:href="@{/recipes/modify(recipeId=${recipe.recipeId})}"
				class="btn btn-warning">수정</a> <a
				th:href="@{/recipes/delete(recipeId=${recipe.recipeId})}"
				class="btn btn-danger" onclick="return confirm('삭제하시겠습니까?')">삭제</a>

			<a th:href="@{/recipes/list}" class="btn btn-secondary">목록</a>
		</div>

	</div>
</body>
</html>
