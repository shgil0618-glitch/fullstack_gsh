<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org"
      xmlns:layout="http://www.ultraq.net.nz/thymeleaf/layout"
      layout:decorate="~{fragments/layout}">
<head lang="ko">
  <meta charset="UTF-8">
  <title>레시피 수정</title>
</head>
<body>
  <div layout:fragment="content">
    <h3>레시피 수정</h3>

    <form th:action="@{/recipes/edit}" th:object="${dto}" method="post" enctype="multipart/form-data">
      <input type="hidden" th:field="*{recipeId}"/>

      <div>
        <label>제목</label>
        <input type="text" th:field="*{title}" required/>
      </div>

      <div>
        <label>카테고리</label>
        <select th:field="*{category}">
          <option th:each="c : ${categories}" th:value="${c['CATEGORY']}" th:text="${c['CATEGORY_NAME']}">카테고리</option>
        </select>
      </div>

      <div>
        <label>현재 이미지</label>
        <div th:if="${dto.image != null}">
          <img th:src="@{${'/upload/' + dto.image}}" alt="이미지" style="max-width:200px;"/>
        </div>
        <div>
          <label>이미지 변경</label>
          <input type="file" name="imageFile" accept="image/*"/>
        </div>
      </div>

      <div>
        <label>요리시간</label>
        <input type="text" th:field="*{cookTime}"/>
      </div>

      <div>
        <label>난이도</label>
        <input type="text" th:field="*{difficulty}"/>
      </div>

      <div>
        <label>인분</label>
        <input type="text" th:field="*{servings}"/>
      </div>

      <div>
        <label>설명</label>
        <textarea th:field="*{description}"></textarea>
      </div>

      <!-- 재료 편집 -->
      <div>
        <label>재료</label>
        <div th:each="ing, idx : ${ingredients}">
          <input type="hidden" th:name="${'ingreList[' + idx.index + '].ingreMapId'}" th:value="${ing.ingreMapId}"/>
          <input type="text" th:name="${'ingreList[' + idx.index + '].ingreName'}" th:value="${ing.ingreName}" placeholder="재료명"/>
          <input type="text" th:name="${'ingreList[' + idx.index + '].ingreNum'}" th:value="${ing.ingreNum}" placeholder="수량"/>
        </div>
        <!-- 필요 시 JS로 항목 추가 -->
      </div>

      <!-- 단계 편집 -->
      <div>
        <label>조리 단계</label>
        <div th:each="step, idx : ${steps}">
          <input type="hidden" th:name="${'stepList[' + idx.index + '].stepMapId'}" th:value="${step.stepMapId}"/>
          <textarea th:name="${'stepList[' + idx.index + '].stepDesc'}" th:text="${step.stepDesc}" placeholder="단계 설명"></textarea>
          <input type="text" th:name="${'stepList[' + idx.index + '].stepImage'}" th:value="${step.stepImage}" placeholder="이미지 경로(선택)"/>
        </div>
      </div>

      <div>
        <button type="submit">수정 저장</button>
        <a th:href="@{/recipes/view(recipeId=${dto.recipeId})}">취소</a>
      </div>
    </form>
  </div>
</body>
</html>
