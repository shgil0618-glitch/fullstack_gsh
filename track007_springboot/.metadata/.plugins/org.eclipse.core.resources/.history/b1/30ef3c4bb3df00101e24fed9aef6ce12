    int updateBadWord(Map<String, Object> params); // wordId, newWord
    int deleteBadWordById(int wordId);
    int deleteBadWordByWord(String word);
    List<Map<String, Object>> selectAllBadWords();

    // ai usage
    int insertAiUsage(Map<String, Object> params); // aiHistId generated by selectKey in XML
    List<Map<String, Object>> selectAllAiUsage();
    List<Map<String, Object>> selectAiUsageByUser(int appUserId);
    int deleteAiUsageById(int aiHistId);
    int deleteAiUsageByUser(int appUserId);

    // category
    List<Map<String, Object>> selectAllCategories();
    String selectCategoryName(int category);
