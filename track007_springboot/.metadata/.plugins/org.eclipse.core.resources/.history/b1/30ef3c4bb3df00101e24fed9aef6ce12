    // recipes3
    int insertRecipe(Recipes3Dto recipe);
    int updateRecipe(Recipes3Dto recipe);
    int deleteRecipe(int recipeId);
    Recipes3Dto selectRecipeById(int recipeId);
    List<Recipes3Dto> selectRecipeAllPaged(Map<String, Object> params); // rStart, rEnd, category
    int countSearchRecipes(Map<String, Object> params);
    List<Recipes3Dto> searchRecipesPaged(Map<String, Object> params); // rStart, rEnd, keyword, searchField, sort, category
    int incrementViews(int recipeId);

    // recipes_ingre3
    int insertIngre(RecipesIngre3 ingre);
    int deleteIngreByRecipeId(int recipeId);
    List<RecipesIngre3> selectIngreByRecipeId(int recipeId);

    // recipes_step3
    int insertStep(RecipesStep3 step);
