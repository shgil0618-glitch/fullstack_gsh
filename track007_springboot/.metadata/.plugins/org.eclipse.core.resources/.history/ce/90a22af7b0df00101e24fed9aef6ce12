package com.thejoa703.controller;

import java.security.Principal;
import java.util.*;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.servlet.mvc.support.RedirectAttributes;

import com.thejoa703.dto.*;
import com.thejoa703.service.AppUserService;
import com.thejoa703.service.RecipeService;

@Controller
@RequestMapping("/recipe")
public class RecipeController {

    @Autowired
    private RecipeService recipeService;

    @Autowired
    private AppUserService appUserService;

    /* ==================================================
     * 1️⃣ LIST (페이징)
     * ================================================== */
    @GetMapping("/list")
    public String list(
            @RequestParam(value = "pstartno", defaultValue = "1") int current,
            Model model) {

        int totalCount = recipeService.searchBothCount(new HashMap<>());

        PagingDto paging = new PagingDto(totalCount, current);

        Map<String, Object> param = new HashMap<>();
        param.put("rStart", paging.getRStart());
        param.put("rEnd", paging.getREnd());

        List<Recipes3Dto> list = recipeService.selectRecipeListPaging(param);

        model.addAttribute("list", list);
        model.addAttribute("paging", paging);

        return "/recipe/list";
    }

    /* ==================================================
     * 2️⃣ DETAIL
     * ================================================== */
    @GetMapping("/detail")
    public String detail(
            @RequestParam("recipeId") int recipeId,
            Principal principal,
            Model model,
            RedirectAttributes rttr) {

        Recipes3Dto recipe = recipeService.selectRecipe(recipeId);
        if (recipe == null) {
            rttr.addFlashAttribute("result", "존재하지 않는 레시피입니다.");
            return "redirect:/recipe/list";
        }

        recipeService.incrementRecipeViews(recipeId);

        List<RecipesIngre3> ingredients =
                recipeService.selectRecipeIngredients(recipeId);
        List<RecipesStep3> steps =
                recipeService.selectRecipeSteps(recipeId);

        model.addAttribute("recipe", recipe);
        model.addAttribute("ingredients", ingredients);
        model.addAttribute("steps", steps);

        // 로그인 사용자 & 좋아요 여부
        if (principal != null) {
            AppUserDto user =
                    appUserService.selectEmail(principal.getName(), "local");
            if (user != null) {
                boolean liked = recipeService.existsRecipeLike(
                        user.getAppUserId(), recipeId);
                model.addAttribute("liked", liked);
            }
        }

        model.addAttribute("likeCount",
                recipeService.countRecipeLikes(recipeId));

        return "/recipe/detail";
    }

    /* ==================================================
     * 3️⃣ REGISTER
     * ================================================== */
    @PreAuthorize("isAuthenticated()")
    @GetMapping("/register")
    public String registerForm() {
        return "/recipe/register";
    }

    @PreAuthorize("isAuthenticated()")
    @PostMapping("/register")
    public String register(
            Recipes3Dto recipe,
            @RequestParam("ingreNames") List<String> ingreNames,
            @RequestParam("ingreNums") List<String> ingreNums,
            @RequestParam("stepDescs") List<String> stepDescs,
            Principal principal,
            RedirectAttributes rttr) {

        AppUserDto user =
                appUserService.selectEmail(principal.getName(), "local");
        recipe.setAppUserId(user.getAppUserId());

        // 재료 DTO 변환
        List<RecipesIngre3> ingredients = new ArrayList<>();
        for (int i = 0; i < ingreNames.size(); i++) {
            RecipesIngre3 ingre = new RecipesIngre3();
            ingre.setIngreName(ingreNames.get(i));
            ingre.setIngreNum(ingreNums.get(i));
            ingredients.add(ingre);
        }

        // 단계 DTO 변환
        List<RecipesStep3> steps = new ArrayList<>();
        for (int i = 0; i < stepDescs.size(); i++) {
            RecipesStep3 step = new RecipesStep3();
            step.setStepDesc(stepDescs.get(i));
            steps.add(step);
        }

        recipeService.insertRecipe(recipe, ingredients, steps);

        rttr.addFlashAttribute("result", "레시피 등록 완료");
        return "redirect:/recipe/list";
    }

    /* ==================================================
     * 4️⃣ MODIFY
     * ================================================== */
    @PreAuthorize("isAuthenticated()")
    @PostMapping("/modify")
    public String modify(
            Recipes3Dto recipe,
            @RequestParam("ingreNames") List<String> ingreNames,
            @RequestParam("ingreNums") List<String> ingreNums,
            @RequestParam("stepDescs") List<String> stepDescs,
            Principal principal,
            RedirectAttributes rttr) {

        AppUserDto user =
                appUserService.selectEmail(principal.getName(), "local");
        recipe.setAppUserId(user.getAppUserId());

        List<RecipesIngre3> ingredients = new ArrayList<>();
        for (int i = 0; i < ingreNames.size(); i++) {
            RecipesIngre3 ingre = new RecipesIngre3();
            ingre.setIngreName(ingreNames.get(i));
            ingre.setIngreNum(ingreNums.get(i));
            ingredients.add(ingre);
        }

        List<RecipesStep3> steps = new ArrayList<>();
        for (int i = 0; i < stepDescs.size(); i++) {
            RecipesStep3 step = new RecipesStep3();
            step.setStepDesc(stepDescs.get(i));
            steps.add(step);
        }

        recipeService.updateRecipe(recipe, ingredients, steps);

        rttr.addFlashAttribute("result", "레시피 수정 완료");
        return "redirect:/recipe/detail?recipeId=" + recipe.getRecipeId();
    }

    /* ==================================================
     * 5️⃣ DELETE
     * ================================================== */
    @PreAuthorize("isAuthenticated()")
    @PostMapping("/delete")
    public String delete(
            @RequestParam("recipeId") int recipeId,
            RedirectAttributes rttr) {

        recipeService.deleteRecipe(recipeId);
        rttr.addFlashAttribute("result", "레시피 삭제 완료");

        return "redirect:/recipe/list";
    }

    /* ==================================================
     * 6️⃣ LIKE (좋아요)
     * ================================================== */
    @PreAuthorize("isAuthenticated()")
    @PostMapping("/like")
    @ResponseBody
    public Map<String, Object> toggleLike(
            @RequestParam("recipeId") int recipeId,
            Principal principal) {

        AppUserDto user =
                appUserService.selectEmail(principal.getName(), "local");

        boolean exists = recipeService.existsRecipeLike(
                user.getAppUserId(), recipeId);

        if (exists) {
            recipeService.deleteRecipeLike(
                    user.getAppUserId(), recipeId);
        } else {
            RecipeLikes3 like = new RecipeLikes3();
            like.setAppUserId(user.getAppUserId());
            like.setRecipeId(recipeId);
            recipeService.insertRecipeLike(like);
        }

        Map<String, Object> result = new HashMap<>();
        result.put("liked", !exists);
        result.put("count",
                recipeService.countRecipeLikes(recipeId));

        return result;
    }
}
