package com.thejoa703.service;

import com.thejoa703.dao.Recipes3Dao;
import com.thejoa703.dto.*;
import org.springframework.stereotype.Service;
import org.springframework.beans.factory.annotation.Autowired;
import java.util.List;
import java.util.Map;

@Service
public class RecipeServiceImpl implements RecipeService {

    @Autowired
    private Recipes3Dao recipes3Dao;

    @Override
    public int createRecipe(Recipes3Dto recipe) {
        return recipes3Dao.insertRecipe(recipe);
    }

    @Override
    public Recipes3Dto getRecipe(int recipeId) {
        recipes3Dao.incrementRecipeViews(recipeId);
        return recipes3Dao.selectRecipe(recipeId);
    }

    @Override
    public int updateRecipe(Recipes3Dto recipe) {
        return recipes3Dao.updateRecipe(recipe);
    }

    @Override
    public int deleteRecipe(int recipeId) {
        return recipes3Dao.deleteRecipe(recipeId);
    }

    @Override
    public void incrementViews(int recipeId) {
        recipes3Dao.incrementRecipeViews(recipeId);
    }

    @Override
    public List<RecipesIngre3> getRecipeIngredients(int recipeId) {
        return recipes3Dao.selectRecipeIngredients(recipeId);
    }

    @Override
    public List<RecipesStep3> getRecipeSteps(int recipeId) {
        return recipes3Dao.selectRecipeSteps(recipeId);
    }

    @Override
    public int getSearchCount(Map<String, Object> params) {
        return recipes3Dao.searchBothCount(params);
    }

    @Override
    public List<Recipes3Dto> searchRecipes(Map<String, Object> params) {
        return recipes3Dao.searchBothPaging(params);
    }

    @Override
    public boolean likeRecipe(int appUserId, int recipeId) {
        return recipes3Dao.insertRecipeLike(new RecipeLikes3(appUserId, recipeId)) > 0;
    }

    @Override
    public boolean unlikeRecipe(int appUserId, int recipeId) {
        return recipes3Dao.deleteRecipeLike(Map.of("appUserId", appUserId, "recipeId", recipeId)) > 0;
    }

    @Override
    public boolean hasLiked(int appUserId, int recipeId) {
        return recipes3Dao.existsRecipeLike(Map.of("appUserId", appUserId, "recipeId", recipeId)) > 0;
    }

    @Override
    public int countLikes(int recipeId) {
        return recipes3Dao.countRecipeLikes(recipeId);
    }

    @Override
    public List<Recipes3Dto> getMyLikedRecipes(int appUserId) {
        return recipes3Dao.selectMyLikedRecipes(appUserId);
    }

    @Override
    public int insertAiUsage(AiUsageHistory3 aiHistory) {
        return recipes3Dao.insertAiUsageHistory(aiHistory);
    }

    @Override
    public List<AiUsageHistory3> getAiUsageByUser(int appUserId) {
        return recipes3Dao.selectAiUsageByUser(appUserId);
    }

    @Override
    public List<AiUsageHistory3> getAllAiUsage() {
        return recipes3Dao.selectAllAiUsage();
    }

    @Override
    public List<BadWords3> getBadWords() {
        return recipes3Dao.selectBadWords();
    }
}
