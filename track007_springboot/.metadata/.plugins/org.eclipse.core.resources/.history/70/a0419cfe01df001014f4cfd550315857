<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org"
   xmlns:layout="http://www.ultraq.net.nz/thymeleaf/layout"
   layout:decorate="~{fragments/layout}">
<!--    #1. layout 렌더링    -->
<head lang="ko">
<meta charset="UTF-8">
<title>Insert title here</title>
</head>
<body>
   <div layout:fragment="content">
      <script type="text/javascript"
         src="https://oapi.map.naver.com/openapi/v3/maps.js?ncpKeyId=ded9jfxufa&callback=initMap"></script>

      <h2 class="mb-3">📍 현재 위치 기반 매장 추천</h2>

      <!-- 버튼 영역 -->
      <div class="mb-3">
         <button id="locateBtn" class="btn btn-primary me-2">내 위치 찾기</button>
         <button id="showAllBtn" class="btn btn-secondary">모든 매장 표시</button>
      </div>

      <!-- 지도 영역 -->
      <div id="map" class="border rounded"
         style="width: 100%; height: 500px;"></div>

      <!-- 결과 패널 -->
      <div class="card mt-3">
         <div class="card-body">
            <h5 class="card-title">추천 결과</h5>
            <p id="resultText" class="card-text">아직 위치를 찾지 않았습니다.</p>
            <div id="storeList" class="list-group"></div>
         </div>
      </div>
      <!-- 지도 넣기 -->
      <script>
         let map;
         let userMarker;
         let storeMarkers = [];
      
         function initMap() {
      
            // 1. 매장 좌표
            const stores = [
               { name: "강남점", lat: 37.498095, lng: 127.027610 },
               { name: "홍대점", lat: 37.556343, lng: 126.922651 },
               { name: "인천점", lat: 37.447275, lng: 126.690894 },
               { name: "시청점", lat: 37.566295, lng: 126.977945 }
            ];
      
            // 2. 지도 초기화
            map = new naver.maps.Map('map', {
               center: new naver.maps.LatLng(37.3595704, 127.105399),
               zoom: 13
            });
      
            // 3. 기본 사용자 마커
            userMarker = new naver.maps.Marker({
               position: new naver.maps.LatLng(37.3595704, 127.105399),
               map: map,
               zIndex: 9999
            });
      
            // 4. 버튼 이벤트 연결
            document.getElementById("locateBtn").onclick = recommend;
            document.getElementById("showAllBtn").onclick = showStores;
      
            // 5. 모든 매장 마커 표시
            function showStores() {
               storeMarkers.forEach(m => m.setMap(null));
               storeMarkers = [];
      
               stores.forEach(store => {
                  const marker = new naver.maps.Marker({
                     position: new naver.maps.LatLng(store.lat, store.lng),
                     map: map
                  });
                  storeMarkers.push(marker);
               });
      
               document.getElementById("resultText").innerText = "모든 매장을 표시했습니다.";
            }
      
            // 6. 현재 위치 찾기
            function recommend() {
               if (!navigator.geolocation) {
                  alert("위치 정보를 지원하지 않는 브라우저입니다.");
                  return;
               }
      
               navigator.geolocation.getCurrentPosition(pos => {
                  const userPos = new naver.maps.LatLng(
                     pos.coords.latitude,
                     pos.coords.longitude
                  );
      
                  userMarker.setPosition(userPos);
                  map.setCenter(userPos);
      
                  document.getElementById("resultText").innerText = "현재 위치를 찾았습니다.";
               });
            }
         }
      </script>
   </div>
   <!--    http://localhost:8484/boot001/board/list -->
</body>
</html>