package com.thejoa703;

import static org.junit.jupiter.api.Assertions.*;

import java.util.List;
import java.util.UUID;

import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.transaction.annotation.Transactional;
import org.springframework.mock.web.MockMultipartFile;

import com.thejoa703.dto.Recipes3Dto;

@SpringBootTest
@Transactional   // 테스트 실행 중 DB 변경 자동 롤백
class RecipesServiceTests {

    @Autowired
    private RecipesServiceTests recipeService;

    @Test
    void testRecipeCRUD() {
        // ===============================
        // 1️⃣ 레시피 등록
        // ===============================
        Recipes3Dto dto = new Recipes3Dto();
        dto.setTitle("테스트 레시피 " + UUID.randomUUID());
        dto.setCategory("MAIN");
        dto.setCookTime("30분");
        dto.setDifficulty("중");
        dto.setServings(2);
        dto.setDescription("테스트용 레시피 설명");
        dto.setAppUserId(1); // 테스트용 사용자 ID
        dto.setNickname("테스트유저");

        MockMultipartFile file = new MockMultipartFile(
                "file", "test.txt", "text/plain", "테스트 데이터".getBytes()
        );

        int insertResult = recipeService.insert(dto, List.of(file));
        assertEquals(1, insertResult, "레시피 등록 실패");

        int recipeId = dto.getRecipeId(); // insert 후 생성된 ID

        // ===============================
        // 2️⃣ 상세조회
        // ===============================
        Recipes3Dto detail = recipeService.selectRecipeDetail(recipeId);
        assertNotNull(detail, "레시피 상세 조회 실패");
        assertEquals(dto.getTitle(), detail.getTitle());

        // ===============================
        // 3️⃣ 레시피 목록 조회 (페이징)
        // ===============================
        List<Recipes3Dto> list = recipeService.selectRecipeListPaging(1);
        assertNotNull(list, "레시피 목록 조회 실패");
        assertTrue(list.stream().anyMatch(r -> r.getRecipeId() == recipeId));

        // ===============================
        // 4️⃣ 레시피 수정
        // ===============================
        detail.setTitle("수정된 레시피 제목");
        int updateResult = recipeService.update(detail, null);
        assertEquals(1, updateResult, "레시피 수정 실패");

        Recipes3Dto updated = recipeService.selectRecipeDetail(recipeId);
        assertEquals("수정된 레시피 제목", updated.getTitle());

        // ===============================
        // 5️⃣ 레시피 삭제
        // ===============================
        int deleteResult = recipeService.delete(recipeId, dto.getAppUserId());
        assertEquals(1, deleteResult, "레시피 삭제 실패");

        Recipes3Dto deleted = recipeService.selectRecipeDetail(recipeId);
        assertNull(deleted, "삭제된 레시피가 조회됨");
    }
}
