package com.thejoa703.dao;

import java.util.List;
import java.util.Map;

import org.apache.ibatis.annotations.Mapper;

import com.thejoa703.dto.Recipes3Dto;

@Mapper
public interface Recipes3Dao {
    // recipes3
    int insertRecipe(Recipes3Dto recipe);
    int updateRecipe(Recipes3Dto recipe);
    int deleteRecipe(long recipeId);
    Recipes3Dto selectRecipeById(long recipeId);
    List<Recipes3Dto> selectRecipeAllPaged(Map<String, Object> params); // rStart, rEnd, category
    int countSearchRecipes(Map<String, Object> params);
    List<Recipes3Dto> searchRecipesPaged(Map<String, Object> params); // rStart, rEnd, keyword, searchField, sort, category
    int incrementViews(long recipeId);

    // recipes_ingre3
    int insertIngre(IngredientDto ingre);
    int deleteIngreByRecipeId(long recipeId);
    List<IngredientDto> selectIngreByRecipeId(long recipeId);

    // recipes_step3
    int insertStep(StepDto step);
    int deleteStepByRecipeId(long recipeId);
    List<StepDto> selectStepByRecipeId(long recipeId);

    // likes
    int insertLike(Map<String, Object> params); // appUserId, recipeId
    int deleteLike(Map<String, Object> params);
    int countLikesByRecipe(long recipeId);
    int existsLike(Map<String, Object> params);

    // search history
    int insertSearchHistory(Map<String, Object> params); // appUserId, keyword
    List<Map<String, Object>> topKeywords(int limit);

    // bad words
    List<String> containsBadWords(String text);
    int existsBadWord(String word);
    int insertBadWord(Map<String, Object> params); // wordId generated by selectKey in XML
    int updateBadWord(Map<String, Object> params); // wordId, newWord
    int deleteBadWordById(long wordId);
    int deleteBadWordByWord(String word);
    List<Map<String, Object>> selectAllBadWords();

    // ai usage
    int insertAiUsage(Map<String, Object> params); // aiHistId generated by selectKey in XML
    List<Map<String, Object>> selectAllAiUsage();
    List<Map<String, Object>> selectAiUsageByUser(long appUserId);
    int deleteAiUsageById(long aiHistId);
    int deleteAiUsageByUser(long appUserId);

    // category
    List<Map<String, Object>> selectAllCategories();
    String selectCategoryName(int category);
}
