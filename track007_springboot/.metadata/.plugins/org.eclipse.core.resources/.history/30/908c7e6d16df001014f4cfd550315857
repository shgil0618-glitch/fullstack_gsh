package com.thejoa703.controller;

import java.security.Principal;
import java.util.List;
import java.util.Map;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.servlet.mvc.support.RedirectAttributes;
import org.springframework.web.multipart.MultipartFile;

import com.thejoa703.dto.RecipeLikes3;
import com.thejoa703.dto.Recipes3Dto;
import com.thejoa703.service.RecipeService;

@Controller
@RequestMapping("/recipe")
public class RecipeController {

    @Autowired
    private RecipeService recipeService;

    // =======================
    // 1. 레시피 목록 / 상세
    // =======================
    @GetMapping("/list")
    public String list(Model model,
                       @RequestParam(value = "page", defaultValue = "1") int page) {
        int totalCount = recipeService.getTotalRecipeCount();
        model.addAttribute("paging", recipeService.getPaging(page, totalCount));
        model.addAttribute("list", recipeService.selectRecipeListPaging(page));
        return "recipe/list";
    }

    @GetMapping("/detail")
    public String detail(@RequestParam("recipeId") int recipeId,
                         Principal principal,
                         Model model,
                         RedirectAttributes rttr) {
        Recipes3Dto recipe = recipeService.selectRecipeDetail(recipeId);
        if (recipe == null) {
            rttr.addFlashAttribute("result", "레시피를 찾을 수 없습니다.");
            return "redirect:/recipe/list";
        }
        recipeService.incrementViews(recipeId);
        model.addAttribute("recipe", recipe);

        if (principal != null) {
            String email = principal.getName();
            int appUserId = recipeService.getAppUserIdByEmail(email);
            boolean liked = recipeService.existsRecipeLike(appUserId, recipeId);
            model.addAttribute("liked", liked);
        }

        return "recipe/detail";
    }

    // =======================
    // 2. 내 레시피 / 마이페이지
    // =======================
    @PreAuthorize("isAuthenticated()")
    @GetMapping("/mylist")
    public String myList(Principal principal, Model model, RedirectAttributes rttr) {
        if (principal == null) {
            rttr.addFlashAttribute("result", "로그인 후 이용 가능합니다.");
            return "redirect:/login";
        }
        int appUserId = recipeService.getAppUserIdByEmail(principal.getName());
        model.addAttribute("list", recipeService.selectMyRecipes(appUserId));
        return "recipe/mylist";
    }

    // =======================
    // 3. 레시피 등록
    // =======================
    @PreAuthorize("isAuthenticated()")
    @GetMapping("/register")
    public String registerForm() {
        return "recipe/register";
    }

    @PreAuthorize("isAuthenticated()")
    @PostMapping("/register")
    public String register(Recipes3Dto dto,
                           @RequestParam(value = "files", required = false) List<MultipartFile> files,
                           Principal principal,
                           RedirectAttributes rttr) {
        try {
            int appUserId = recipeService.getAppUserIdByEmail(principal.getName());
            dto.setAppUserId(appUserId);
            if (recipeService.insertRecipe(dto, files) > 0) {
                rttr.addFlashAttribute("result", "레시피 등록 성공");
            } else {
                rttr.addFlashAttribute("result", "레시피 등록 실패");
            }
        } catch (Exception e) {
            e.printStackTrace();
            rttr.addFlashAttribute("result", "서버 오류 발생");
        }
        return "redirect:/recipe/list";
    }

    // =======================
    // 4. 레시피 수정
    // =======================
    @PreAuthorize("isAuthenticated()")
    @GetMapping("/modify")
    public String modifyForm(@RequestParam("recipeId") int recipeId,
                             Principal principal,
                             Model model,
                             RedirectAttributes rttr) {
        Recipes3Dto recipe = recipeService.selectRecipeDetail(recipeId);
        int appUserId = recipeService.getAppUserIdByEmail(principal.getName());
        if (recipe == null || recipe.getAppUserId() != appUserId) {
            rttr.addFlashAttribute("result", "수정 권한이 없거나 레시피를 찾을 수 없습니다.");
            return "redirect:/recipe/list";
        }
        model.addAttribute("recipe", recipe);
        return "recipe/modify";
    }

    @PreAuthorize("isAuthenticated()")
    @PostMapping("/modify")
    public String modify(Recipes3Dto dto,
                         @RequestParam(value = "files", required = false) List<MultipartFile> files,
                         Principal principal,
                         RedirectAttributes rttr) {
        try {
            int appUserId = recipeService.getAppUserIdByEmail(principal.getName());
            dto.setAppUserId(appUserId);
            if (recipeService.updateRecipe(dto, files) > 0) {
                rttr.addFlashAttribute("result", "레시피 수정 성공");
            } else {
                rttr.addFlashAttribute("result", "레시피 수정 실패");
            }
        } catch (Exception e) {
            e.printStackTrace();
            rttr.addFlashAttribute("result", "서버 오류 발생");
        }
        return "redirect:/recipe/detail?recipeId=" + dto.getRecipeId();
    }

    // =======================
    // 5. 레시피 삭제
    // =======================
    @PreAuthorize("isAuthenticated()")
    @PostMapping("/delete")
    public String delete(@RequestParam("recipeId") int recipeId,
                         Principal principal,
                         RedirectAttributes rttr) {
        try {
            int appUserId = recipeService.getAppUserIdByEmail(principal.getName());
            if (recipeService.deleteRecipe(recipeId, appUserId) > 0) {
                rttr.addFlashAttribute("result", "레시피 삭제 성공");
            } else {
                rttr.addFlashAttribute("result", "삭제 권한이 없습니다.");
            }
        } catch (Exception e) {
            e.printStackTrace();
            rttr.addFlashAttribute("result", "서버 오류 발생");
        }
        return "redirect:/recipe/list";
    }

    // =======================
    // 6. 좋아요 기능
    // =======================
    @PreAuthorize("isAuthenticated()")
    @PostMapping("/like")
    public String like(@RequestParam("recipeId") int recipeId,
                       Principal principal,
                       RedirectAttributes rttr) {
        try {
            int appUserId = recipeService.getAppUserIdByEmail(principal.getName());
            if (!recipeService.existsRecipeLike(appUserId, recipeId)) {
                recipeService.likeRecipe(appUserId, recipeId);
            } else {
                recipeService.unlikeRecipe(appUserId, recipeId);
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
        return "redirect:/recipe/detail?recipeId=" + recipeId;
    }
}
