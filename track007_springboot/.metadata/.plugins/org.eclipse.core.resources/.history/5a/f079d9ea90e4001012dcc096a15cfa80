<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org"
      xmlns:layout="http://www.ultraq.net.nz/thymeleaf/layout"
      layout:decorate="~{fragments/layout}">
<head lang="ko">
  <meta charset="UTF-8">
  <title>레시피 수정</title>
</head>

<body>
<div layout:fragment="content" class="container mt-5">

  <h3>레시피 수정</h3>

  <form th:action="@{/recipes/modify}"
        method="post"
        enctype="multipart/form-data">

    <!-- CSRF -->
    <input type="hidden" th:name="${_csrf.parameterName}"
           th:value="${_csrf.token}"/>

    <!-- recipeId -->
    <input type="hidden" name="recipeId"
           th:value="${recipe.recipeId}"/>

    <!-- 제목 -->
    <div class="mb-3">
      <label class="form-label">레시피 제목 *</label>
      <input type="text"
             class="form-control"
             name="title"
             th:value="${recipe.title}"
             required>
    </div>

    <!-- 카테고리 / 난이도 -->
    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label">카테고리 *</label>
        <select name="category" class="form-select" required>
          <option value="2" th:selected="${recipe.category == 2}">한식</option>
          <option value="3" th:selected="${recipe.category == 3}">양식</option>
          <option value="4" th:selected="${recipe.category == 4}">중식</option>
          <option value="5" th:selected="${recipe.category == 5}">일식</option>
          <option value="6" th:selected="${recipe.category == 6}">디저트</option>
        </select>
      </div>

      <div class="col-md-6 mb-3">
        <label class="form-label">난이도 *</label>
        <select name="difficulty" class="form-select" required>
          <option value="쉬움" th:selected="${recipe.difficulty == '쉬움'}">쉬움</option>
          <option value="보통" th:selected="${recipe.difficulty == '보통'}">보통</option>
          <option value="어려움" th:selected="${recipe.difficulty == '어려움'}">어려움</option>
        </select>
      </div>
    </div>

    <!-- 시간 / 인분 -->
    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label">조리 시간(분)</label>
        <input type="number"
               class="form-control"
               name="cookTime"
               th:value="${recipe.cookTime}">
      </div>

      <div class="col-md-6 mb-3">
        <label class="form-label">인분</label>
        <input type="number"
               class="form-control"
               name="servings"
               th:value="${recipe.servings}">
      </div>
    </div>

    <!-- 대표 이미지 -->
    <div class="mb-3">
      <label class="form-label">현재 대표 이미지</label><br>
      <img th:if="${recipe.image != null}"
           th:src="@{/upload/{img}(img=${recipe.image})}"
           style="max-width: 250px;">
    </div>

    <div class="mb-3">
      <label class="form-label">대표 이미지 변경</label>
      <input type="file"
             class="form-control"
             name="imageFile">
    </div>
    <input type="hidden" name="existingImage" th:value="${recipe.image}">

    <!-- 설명 -->
    <div class="mb-3">
      <label class="form-label">레시피 설명 *</label>
      <textarea class="form-control"
                name="description"
                rows="3"
                th:text="${recipe.description}"
                required></textarea>
    </div>

    <hr>

    <!-- 재료 -->
    <div class="mb-3">
      <div class="d-flex justify-content-between">
        <label class="form-label">재료 *</label>
        <button type="button"
                class="btn btn-sm btn-outline-primary"
                id="addIngredientBtn">+ 재료 추가</button>
      </div>

      <div id="ingredientsContainer">
        <div class="row g-2 mb-2 ingredient-row"
             th:each="ing : ${ingredients}">
          <div class="col-5">
            <input class="form-control"
                   name="ingredients"
                   th:value="${ing.ingreName}">
          </div>
          <div class="col-5">
            <input class="form-control"
                   name="ingreNums"
                   th:value="${ing.ingreNum}">
          </div>
          <div class="col-2 d-grid">
            <button type="button"
                    class="btn btn-danger btn-remove-ingre">삭제</button>
          </div>
        </div>
      </div>
    </div>

    <hr>

    <!-- 단계 -->
    <div class="mb-3">
      <div class="d-flex justify-content-between">
        <label class="form-label">조리 방법 *</label>
        <button type="button"
                class="btn btn-sm btn-outline-primary"
                id="addStepBtn">+ 단계 추가</button>
      </div>

      <div id="stepsContainer">
        <div class="card p-3 mb-2 step-row"
             th:each="st : ${steps}">
          <textarea class="form-control mb-2"
                    name="steps"
                    rows="2"
                    th:text="${st.stepDesc}"></textarea>

          <div th:if="${st.stepImage != null}" class="mb-2">
            <img th:src="@{/upload/{img}(img=${st.stepImage})}"
                 style="max-width: 200px;">
            <input type="hidden" name="existingStepImages" th:value="${st.stepImage}">
          </div>
          

          <input type="file"
                 name="stepImages"
                 class="form-control">

          <button type="button"
                  class="btn btn-sm btn-danger mt-2 btn-remove-step">
            단계 삭제
          </button>
        </div>
      </div>
    </div>
    
    <div class="mb-3">
  <label class="form-label">레시피 URL</label>
  <input type="text" class="form-control"
         name="rUrl"
         th:value="${recipe.rUrl}">
</div>
    <input type="hidden" name="status" value="PUBLIC">

    <input type="hidden" name="status" id="statusInput" value="PUBLIC">

<div class="text-end">
  <button type="submit" class="btn btn-warning" onclick="document.getElementById('statusInput').value='PUBLIC'">
    수정 저장
  </button>
  <button type="submit" class="btn btn-secondary" onclick="document.getElementById('statusInput').value='TEMP'">
    임시 저장
  </button>
</div>

    

  </form>

  <!-- JS -->
  <script>
    const ingreBox = document.getElementById('ingredientsContainer');
    const stepBox = document.getElementById('stepsContainer');

    document.getElementById('addIngredientBtn').onclick = () => {
      const div = document.createElement('div');
      div.className = 'row g-2 mb-2 ingredient-row';
      div.innerHTML = `
        <div class="col-5">
          <input class="form-control" name="ingredients">
        </div>
        <div class="col-5">
          <input class="form-control" name="ingreNums">
        </div>
        <div class="col-2 d-grid">
          <button type="button" class="btn btn-danger btn-remove-ingre">삭제</button>
        </div>`;
      ingreBox.appendChild(div);
    };

    ingreBox.onclick = e => {
      if (e.target.classList.contains('btn-remove-ingre')) {
        e.target.closest('.ingredient-row').remove();
      }
    };

    document.getElementById('addStepBtn').onclick = () => {
      const div = document.createElement('div');
      div.className = 'card p-3 mb-2 step-row';
      div.innerHTML = `
        <textarea class="form-control mb-2" name="steps" rows="2"></textarea>
        <input type="file" name="stepImages" class="form-control">
        <button type="button" class="btn btn-sm btn-danger mt-2 btn-remove-step">
          단계 삭제
        </button>`;
      stepBox.appendChild(div);
    };

    stepBox.onclick = e => {
      if (e.target.classList.contains('btn-remove-step')) {
        e.target.closest('.step-row').remove();
      }
    };
  </script>

</div>
</body>
</html>
