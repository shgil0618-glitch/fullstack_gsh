package com.thejoa703.external;

import java.util.HashMap;
import java.util.Random;

import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Component;

import net.nurigo.java_sdk.api.Message;
import net.nurigo.java_sdk.exceptions.CoolsmsException;

@Component
public class ApiCoolSms {

    @Value("${coolsms.apikey}")
    private String api_key;

    @Value("${coolsms.apisecretkey}")
    private String api_secret;

    public String phoneNumber(String phone) throws CoolsmsException {

        // 1. 인증번호 생성
        Random random = new Random();
        String result = String.format("%06d", random.nextInt(1000000));

        // 2. 메시지 전송
        Message message = new Message(api_key, api_secret);

        HashMap<String, String> params = new HashMap<>();
        params.put("to", phone);
        params.put("from", "01012345678"); // 발신번호 (등록된 번호)
        params.put("type", "SMS");
        params.put("text", "[THEJOA] 인증번호 : [" + result + "] 타인 유출 주의");

        message.send(params);

        return result;
    }
}
