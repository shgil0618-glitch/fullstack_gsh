package com.thejoa703;

import com.thejoa703.dto.Recipes3Dto;

import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.context.SpringBootTest;

import java.util.List;

import static org.junit.jupiter.api.Assertions.*;

@SpringBootTest
public class RecipesServiceTest {

    @Autowired
    private RecipesServiceTest recipesService;

    @Test
    void testSelectRecipeDetail() {
        int testRecipeId = 1; // DB에 존재하는 레시피 ID 사용

        Recipes3Dto recipe = recipesService.selectRecipeDetail(testRecipeId);

        assertNotNull(recipe, "레시피 객체가 null이면 안 됩니다");
        System.out.println("레시피 제목: " + recipe.getTitle());
        System.out.println("작성자 닉네임: " + recipe.getNickname());

        assertNotNull(recipe.getIngredients(), "재료 목록은 null이면 안 됩니다");
        System.out.println("재료 개수: " + recipe.getIngredients().size());
        recipe.getIngredients().forEach(ingre ->
                System.out.println(ingre.getIngreName() + " - " + ingre.getIngreNum())
        );

        assertNotNull(recipe.getSteps(), "조리 단계 목록은 null이면 안 됩니다");
        System.out.println("조리 단계 개수: " + recipe.getSteps().size());
        recipe.getSteps().forEach(step ->
                System.out.println(step.getStepDesc() + " (이미지: " + step.getStepImage() + ")")
        );
    }

    @Test
    void testSelectRecipeListPaging() {
        int page = 1;

        List<Recipes3Dto> recipeList = recipesService.selectRecipeListPaging(page);
        assertNotNull(recipeList, "레시피 목록은 null이면 안 됩니다");
        assertFalse(recipeList.isEmpty(), "레시피 목록이 비어있으면 안 됩니다");

        recipeList.forEach(recipe -> 
                System.out.println(recipe.getRecipeId() + " - " + recipe.getTitle())
        );
    }
}
