<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org"
	xmlns:layout="http://www.ultraq.net.nz/thymeleaf/layout"
	layout:decorate="~{fragments/layout}">
<!--    #1. layout 렌더링    -->
<head lang="ko">
<meta charset="UTF-8">
<title>Insert title here</title>
</head>
<body>
	<div layout:fragment="content">
	<script type="text/javascript" src="https://oapi.map.naver.com/openapi/v3/maps.js?ncpKeyId=nj412svael"></script>
		<h2 class="mb-3">📍 현재 위치 기반 매장 추천</h2>

		<!-- 버튼 영역 -->
		<div class="mb-3">
			<button id="locateBtn" class="btn btn-primary me-2">내 위치 찾기</button>
			<button id="showAllBtn" class="btn btn-secondary">모든 매장 표시</button>
		</div>

		<!-- 지도 영역 -->
		<div id="map" class="border rounded"
			style="width: 100%; height: 500px;"></div>

		<!-- 결과 패널 -->
		<div class="card mt-3">
			<div class="card-body">
				<h5 class="card-title">추천 결과</h5>
				<p id="resultText" class="card-text">아직 위치를 찾지 않았습니다.</p>
				<div id="storeList" class="list-group"></div>
			</div>
		</div>

	</div>

</body>
</html>
