package com.thejoa703.controller;

import java.util.HashMap;
import java.util.Map;

import org.springframework.beans.factory.annotation.Value;
import org.springframework.http.HttpHeaders;
import org.springframework.stereotype.Service;

@Service
public class kakaoPayService {
	
	@Value("${kakaopay.secret-key-dev}")
	private String secretKey;
	
	@Value("${kakaopay.approval-url}")
	private String approval;
	
	@Value("${kakaopay.fail-url}")
	private String fail;
	
	@Value("${kakaopay.cancel-url}")
	private String cancel;
	
	private String tid;	// 결제 준비시 받은 거래 id 저장
	
	// 결제준비
	public Map<String, String> kakaoPayReady(){
		
		String url="https://open-api.kakaopay.com/online/v1/payment/ready";
		
		HttpHeaders headers = new HttpHeaders();
		headers.add("Authorization", "SECRET_KEY " + secretKey);	// 공백주의
		headers.add("Content-Type", "application/json");
		
		Map<String,String> params = new HashMap<>();
		params.put("cid", "TC0ONETIME");	//발급받은 가맹점번호
		params.put("partner_order_id", "partner_order_id");	
		params.put("partner_user_id", "partner_user_id");	
		params.put("item_name", "초코파이");	//상품이름-상품번호
		params.put("quantity", "초코파이");
		params.put("total_amount", "2200");
		params.put("vat_amount", "220");
		params.put("tax_free_amount", "초코파이");
		params.put("approval_url", "초코파이");
		params.put("fail_url", "초코파이");
		params.put("cancel_url", "초코파이");
		
		Map<String, String> result = new HashMap<>();
		return result;
	}
	
	// 결제승인
	
	
}

