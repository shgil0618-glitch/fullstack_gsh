<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org"
      xmlns:layout="http://www.ultraq.net.nz/thymeleaf/layout"
      layout:decorate="~{fragments/layout}">
<head lang="ko">
  <meta charset="UTF-8">
  <title>레시피 수정</title>
</head>
<body>
<div layout:fragment="content" class="container mt-5">

  <h3>레시피 수정</h3>

 <form th:action="@{/recipes/modify}" method="post" enctype="multipart/form-data">


    <!-- CSRF -->
    <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}"/>

    <!-- recipeId -->
    <input type="hidden" name="recipeId" th:value="${recipe.recipeId}"/>

    <!-- 제목 -->
    <div class="mb-3">
      <label class="form-label">레시피 제목 *</label>
      <input type="text" class="form-control" name="title"
             th:value="${recipe.title}" required>
    </div>

    <!-- 카테고리 / 난이도 -->
    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label">카테고리 *</label>
        <select name="category" class="form-select" required>
          <option value="2" th:selected="${recipe.category == 2}">한식</option>
          <option value="3" th:selected="${recipe.category == 3}">양식</option>
          <option value="4" th:selected="${recipe.category == 4}">중식</option>
          <option value="5" th:selected="${recipe.category == 5}">일식</option>
          <option value="6" th:selected="${recipe.category == 6}">디저트</option>
        </select>
      </div>
      <div class="col-md-6 mb-3">
        <label class="form-label">난이도 *</label>
        <select name="difficulty" class="form-select" required>
          <option value="쉬움" th:selected="${recipe.difficulty == '쉬움'}">쉬움</option>
          <option value="보통" th:selected="${recipe.difficulty == '보통'}">보통</option>
          <option value="어려움" th:selected="${recipe.difficulty == '어려움'}">어려움</option>
        </select>
      </div>
    </div>

    <!-- 시간 / 인분 -->
    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label">조리 시간(분)</label>
        <input type="number" class="form-control" name="cookTime"
               th:value="${recipe.cookTime}">
      </div>
      <div class="col-md-6 mb-3">
        <label class="form-label">인분</label>
        <input type="number" class="form-control" name="servings"
               th:value="${recipe.servings}">
      </div>
    </div>

    <!-- 대표 이미지 -->
    <div class="mb-3">
      <label class="form-label">현재 대표 이미지</label><br>
      <img th:if="${recipe.image != null}" th:src="@{/upload/{img}(img=${recipe.image})}" style="max-width:250px;">
    </div>
    <div class="mb-3">
      <label class="form-label">대표 이미지 변경</label>
      <input type="file" class="form-control" name="imageFile">
      <input type="hidden" name="existingImage" th:value="${recipe.image}">
    </div>

    <!-- 설명 -->
    <div class="mb-3">
      <label class="form-label">레시피 설명 *</label>
      <textarea class="form-control" name="description" rows="3" required
                th:text="${recipe.description}"></textarea>
    </div>

    <hr>

    <!-- 재료 -->
    <div class="mb-3">
      <div class="d-flex justify-content-between">
        <label class="form-label">재료 *</label>
        <button type="button" class="btn btn-sm btn-outline-primary" id="addIngredientBtn">+ 재료 추가</button>
      </div>
      <div id="ingredientsContainer">
        <div class="row g-2 mb-2 ingredient-row" th:each="ing, iterStat : ${ingredients}">
          <div class="col-5">
            <input class="form-control"
                   th:name="'ingredients[' + ${iterStat.index} + '].ingreName'"
                   th:value="${ing.ingreName}" required>
          </div>
          <div class="col-5">
            <input class="form-control"
                   th:name="'ingredients[' + ${iterStat.index} + '].ingreNum'"
                   th:value="${ing.ingreNum}" required>
          </div>
          <div class="col-2 d-grid">
            <button type="button" class="btn btn-danger btn-remove-ingre">삭제</button>
          </div>
        </div>
      </div>
    </div>

    <hr>

    <!-- 단계 -->
    <div class="mb-3">
      <div class="d-flex justify-content-between">
        <label class="form-label">조리 방법 *</label>
        <button type="button" class="btn btn-sm btn-outline-primary" id="addStepBtn">+ 단계 추가</button>
      </div>
      <div id="stepsContainer">
        <div class="card p-3 mb-2 step-row" th:each="st, iterStat : ${steps}">
          <label th:text="${iterStat.index + 1} + '단계'"></label>
          <textarea class="form-control mb-2"
                    th:name="'steps[' + ${iterStat.index} + '].stepDesc'"
                    rows="2" th:text="${st.stepDesc}" required></textarea>

          <div th:if="${st.stepImage != null}" class="mb-2">
            <img th:src="@{/upload/{img}(img=${st.stepImage})}" style="max-width:200px;">
            <input type="hidden" th:name="'existingStepImages[' + ${iterStat.index} + ']'" th:value="${st.stepImage}">
          </div>

          <input type="file" th:name="'stepImages'" class="form-control">
          <button type="button" class="btn btn-sm btn-danger mt-2 btn-remove-step">단계 삭제</button>
        </div>
      </div>
    </div>

    <!-- URL -->
    <div class="mb-3">
      <label class="form-label">레시피 URL</label>
      <input type="text" class="form-control" name="rUrl" th:value="${recipe.rUrl}">
    </div>

    <input type="hidden" name="status" value="PUBLIC">

    <!-- 버튼 -->
    <div class="text-end">
      <button type="submit" class="btn btn-warning">수정 저장</button>
      <button type="button" class="btn btn-secondary" onclick="saveTemp()">임시저장</button>
    </div>

  </form>

  <!-- JS -->
  <script>
    const ingreBox = document.getElementById('ingredientsContainer');
    const stepBox = document.getElementById('stepsContainer');

    function reindexIngredients() {
      document.querySelectorAll('.ingredient-row').forEach((row, idx) => {
        row.querySelector('[name$="ingreName"]').name = `ingredients[${idx}].ingreName`;
        row.querySelector('[name$="ingreNum"]').name = `ingredients[${idx}].ingreNum`;
      });
    }

    function reindexSteps() {
      document.querySelectorAll('.step-row').forEach((row, idx) => {
        row.querySelector('label').textContent = `${idx+1}단계`;
        row.querySelector('textarea').name = `steps[${idx}].stepDesc`;
        const hidden = row.querySelector('input[type=hidden]');
        if(hidden) hidden.name = `existingStepImages[${idx}]`;
      });
    }

    document.getElementById('addIngredientBtn').onclick = () => {
      const idx = document.querySelectorAll('.ingredient-row').length;
      const div = document.createElement('div');
      div.className = 'row g-2 mb-2 ingredient-row';
      div.innerHTML = `
        <div class="col-5">
          <input class="form-control" name="ingredients[${idx}].ingreName" required>
        </div>
        <div class="col-5">
          <input class="form-control" name="ingredients[${idx}].ingreNum" required>
        </div>
        <div class="col-2 d-grid">
          <button type="button" class="btn btn-danger btn-remove-ingre">삭제</button>
        </div>`;
      ingreBox.appendChild(div);
    };

    ingreBox.onclick = e => {
      if(e.target.classList.contains('btn-remove-ingre')) {
        e.target.closest('.ingredient-row').remove();
        reindexIngredients();
      }
    };

    document.getElementById('addStepBtn').onclick = () => {
      const idx = document.querySelectorAll('.step-row').length;
      const div = document.createElement('div');
      div.className = 'card p-3 mb-2 step-row';
      div.innerHTML = `
        <label>${idx+1}단계</label>
        <textarea class="form-control mb-2" name="steps[${idx}].stepDesc" rows="2" required></textarea>
        <input type="file" name="stepImages" class="form-control">
        <button type="button" class="btn btn-sm btn-danger mt-2 btn-remove-step">단계 삭제</button>`;
      stepBox.appendChild(div);
    };

    stepBox.onclick = e => {
      if(e.target.classList.contains('btn-remove-step')) {
        e.target.closest('.step-row').remove();
        reindexSteps();
      }
    };

    function saveTemp() {
      const form = document.querySelector('form');
      const statusInput = form.querySelector('input[name=status]');
      statusInput.value = 'TEMP';
      form.submit();
    }
  </script>

</div>
</body>
</html>
