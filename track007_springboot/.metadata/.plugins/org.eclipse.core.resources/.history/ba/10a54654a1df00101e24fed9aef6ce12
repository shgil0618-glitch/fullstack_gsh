package com.thejoa703.controller;

import com.thejoa703.dto.PagingDto;
import com.thejoa703.dto.Recipes3;
import com.thejoa703.dto.RecipesIngre3;
import com.thejoa703.dto.RecipesStep3;
import com.thejoa703.service.Recipes3Service;
import com.thejoa703.service.AppUserSecurityService;
import com.thejoa703.service.AppUserService;
import com.thejoa703.service.RecipeService;

import lombok.RequiredArgsConstructor;

import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.multipart.MultipartFile;
import org.springframework.web.servlet.mvc.support.RedirectAttributes;

import org.springframework.security.access.prepost.PreAuthorize;

import java.security.Principal;
import java.util.List;
import java.util.Map;

@Controller
@RequestMapping("/recipe/*")
public class RecipeController {

    private final RecipeService recipeService;
    private final AppUserService userService;

    // ======================================================
    // 1️⃣ LIST / MAIN PAGE
    // ======================================================
    @GetMapping("/main")
    public String main(Model model,
                       @RequestParam(value = "pstartno", defaultValue = "1") int currentPage) {

        int totalCount = recipeService.getTotalRecipeCount();
        PagingDto paging = new PagingDto(totalCount, currentPage);

        List<Recipes3> recipeList = recipeService.getRecipesList(currentPage);

        model.addAttribute("paging", paging);
        model.addAttribute("list", recipeList);
        return "/recipe/main";
    }

    @GetMapping("/list")
    public String list(Model model,
                       @RequestParam(value = "pstartno", defaultValue = "1") int currentPage) {

        int totalCount = recipeService.getTotalRecipeCount();
        PagingDto paging = new PagingDto(totalCount, currentPage);

        List<Recipes3> recipeList = recipeService.getRecipesList(currentPage);

        model.addAttribute("paging", paging);
        model.addAttribute("list", recipeList);
        return "/recipe/list";
    }

    // ======================================================
    // 2️⃣ DETAIL
    // ======================================================
    @GetMapping("/detail")
    public String detail(@RequestParam("recipeId") Long recipeId,
                         Principal principal,
                         Model model,
                         RedirectAttributes rttr) {

        Recipes3 recipe = recipeService.getRecipe(recipeId);
        if (recipe == null) {
            rttr.addFlashAttribute("result", "레시피를 찾을 수 없습니다.");
            return "redirect:/recipe/list";
        }

        // 조회수 증가
        recipeService.incrementViews(recipeId);

        model.addAttribute("recipe", recipe);

        if (principal != null) {
            var user = userService.selectEmail(principal.getName());
            if (user != null) model.addAttribute("loginUser", user);
        }

        return "/recipe/detail";
    }

    // ======================================================
    // 3️⃣ MY LIST
    // ======================================================
    @PreAuthorize("isAuthenticated()")
    @GetMapping("/mylist")
    public String myList(Principal principal, Model model, RedirectAttributes rttr) {
        if (principal == null) {
            rttr.addFlashAttribute("result", "로그인 후 이용 가능합니다.");
            return "redirect:/login";
        }
        var user = userService.selectEmail(principal.getName());
        if (user == null) {
            rttr.addFlashAttribute("result", "사용자 정보를 찾을 수 없습니다.");
            return "redirect:/recipe/list";
        }
        List<Recipes3> myList = recipeService.getMyRecipes(user.getAppUserId());
        model.addAttribute("list", myList);
        return "/recipe/mylist";
    }

    // ======================================================
    // 4️⃣ CREATE
    // ======================================================
    @PreAuthorize("isAuthenticated()")
    @GetMapping("/register")
    public String registerForm() {
        return "/recipe/register";
    }

    @PreAuthorize("isAuthenticated()")
    @PostMapping("/register")
    public String register(@ModelAttribute Recipes3 recipe,
                           @RequestParam(value = "ingredients", required = false) List<String> ingreList,
                           @RequestParam(value = "steps", required = false) List<String> stepList,
                           Principal principal,
                           RedirectAttributes rttr) {

        String resultMessage = "레시피 등록 실패";

        try {
            if (principal == null) {
                rttr.addFlashAttribute("result", "로그인 후 이용 가능합니다.");
                return "redirect:/login";
            }

            var user = userService.selectEmail(principal.getName());
            recipe.setAppUserId(user.getAppUserId());
            recipe.setNickname(userService.selectUserNickname(user.getAppUserId()));

            recipeService.createRecipeWithIngreStep(recipe, ingreList, stepList);
            resultMessage = "레시피 등록 성공";

        } catch (Exception e) {
            e.printStackTrace();
            resultMessage = "레시피 등록 중 서버 오류 발생";
        }

        rttr.addFlashAttribute("result", resultMessage);
        return "redirect:/recipe/list";
    }

    // ======================================================
    // 5️⃣ UPDATE
    // ======================================================
    @PreAuthorize("isAuthenticated()")
    @GetMapping("/modify")
    public String modifyForm(@RequestParam("recipeId") Long recipeId,
                             Principal principal,
                             Model model,
                             RedirectAttributes rttr) {

        if (principal == null) return "redirect:/login";
        var user = userService.selectEmail(principal.getName());

        Recipes3 recipe = recipeService.getRecipe(recipeId);
        if (recipe == null || recipe.getAppUserId() != user.getAppUserId()) {
            rttr.addFlashAttribute("result", "수정 권한이 없거나 레시피를 찾을 수 없습니다.");
            return "redirect:/recipe/detail?recipeId=" + recipeId;
        }

        // 재료와 단계도 가져오기
        List<RecipesIngre3> ingredients = recipeService.getRecipeIngredients(recipeId);
        List<RecipesStep3> steps = recipeService.getRecipeSteps(recipeId);

        model.addAttribute("recipe", recipe);
        model.addAttribute("ingredients", ingredients);
        model.addAttribute("steps", steps);

        return "/recipe/modify";
    }

    @PreAuthorize("isAuthenticated()")
    @PostMapping("/modify")
    public String modify(@ModelAttribute Recipes3 recipe,
                         @RequestParam(value = "ingredients", required = false) List<String> ingreList,
                         @RequestParam(value = "steps", required = false) List<String> stepList,
                         Principal principal,
                         RedirectAttributes rttr) {

        String resultMessage = "레시피 수정 실패";

        try {
            var user = userService.selectEmail(principal.getName());
            recipe.setAppUserId(user.getAppUserId());

            recipeService.updateRecipeWithIngreStep(recipe, ingreList, stepList);
            resultMessage = "레시피 수정 성공";

        } catch (Exception e) {
            e.printStackTrace();
            resultMessage = "레시피 수정 중 오류 발생";
        }

        rttr.addFlashAttribute("result", resultMessage);
        return "redirect:/recipe/detail?recipeId=" + recipe.getRecipeId();
    }

    // ======================================================
    // 6️⃣ DELETE
    // ======================================================
    @PreAuthorize("isAuthenticated()")
    @PostMapping("/delete")
    public String deleteRecipe(@RequestParam("recipeId") Long recipeId,
                               Principal principal,
                               RedirectAttributes rttr) {

        String resultMessage = "레시피 삭제 실패";

        try {
            var user = userService.selectEmail(principal.getName());
            if (recipeService.deleteRecipe(recipeId, user.getAppUserId()) > 0) {
                resultMessage = "레시피 삭제 성공";
            } else {
                resultMessage = "레시피 삭제 권한이 없습니다.";
            }
        } catch (Exception e) {
            e.printStackTrace();
            resultMessage = "레시피 삭제 중 오류 발생";
        }

        rttr.addFlashAttribute("result", resultMessage);
        return "redirect:/recipe/list";
    }

    // ======================================================
    // 7️⃣ LIKE 기능
    // ======================================================
    @PreAuthorize("isAuthenticated()")
    @PostMapping("/like")
    @ResponseBody
    public String likeRecipe(@RequestParam("recipeId") Long recipeId,
                             Principal principal) {

        var user = userService.selectEmail(principal.getName());
        int userId = user.getAppUserId();

        boolean exists = recipeService.existsRecipeLike(userId, recipeId) > 0;

        if (exists) {
            recipeService.deleteRecipeLike(userId, recipeId);
            return "unliked";
        } else {
            recipeService.insertRecipeLike(userId, recipeId);
            return "liked";
        }
    }

    @GetMapping("/likeCount")
    @ResponseBody
    public int getLikeCount(@RequestParam("recipeId") Long recipeId) {
        return recipeService.countRecipeLikes(recipeId);
    }

    @GetMapping("/myLiked")
    public String myLikedRecipes(Principal principal, Model model) {
        var user = userService.selectEmail(principal.getName());
        List<Recipes3> likedList = recipeService.selectMyLikedRecipes(user.getAppUserId());
        model.addAttribute("list", likedList);
        return "/recipe/myLiked";
    }
}
