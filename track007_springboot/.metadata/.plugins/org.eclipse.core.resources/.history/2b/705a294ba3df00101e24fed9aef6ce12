<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.thejoa703.dao.Recipes3Dao">

    <!-- ==================================================
         RESULT MAP (RECIPE)
    ================================================== -->

    <resultMap id="recipes3ResultMap" type="com.thejoa703.dto.Recipes3Dto">
        <id property="recipeId" column="RECIPE_ID"/>
        <result property="appUserId" column="APPUSERID"/>
        <result property="title" column="TITLE"/>
        <result property="category" column="CATEGORY"/>
        <result property="categoryName" column="CATEGORY_NAME"/>
        <result property="image" column="IMAGE"/>
        <result property="cookTime" column="COOK_TIME"/>
        <result property="difficulty" column="DIFFICULTY"/>
        <result property="servings" column="SERVINGS"/>
        <result property="description" column="DESCRIPTION"/>
        <result property="status" column="STATUS"/>
        <result property="createdAt" column="CREATED_AT"/>
        <result property="updatedAt" column="UPDATED_AT"/>
        <result property="views" column="VIEWS"/>
        <result property="rUrl" column="R_URL"/>
        <result property="nickname" column="NICKNAME"/>
    </resultMap>

    <!-- ==================================================
         1️⃣ RECIPE
    ================================================== -->

    <insert id="insertRecipe" parameterType="com.thejoa703.dto.Recipes3Dto">
        <selectKey keyProperty="recipeId" resultType="int" order="BEFORE">
            SELECT seq_recipe3.NEXTVAL FROM dual
        </selectKey>
        INSERT INTO recipes3 (
            RECIPE_ID, APPUSERID, TITLE, CATEGORY, IMAGE,
            COOK_TIME, DIFFICULTY, SERVINGS,
            DESCRIPTION, STATUS, R_URL,
            CREATED_AT, VIEWS
        ) VALUES (
            #{recipeId}, #{appUserId}, #{title}, #{category}, #{image},
            #{cookTime}, #{difficulty}, #{servings},
            #{description}, #{status}, #{rUrl},
            SYSDATE, 0
        )
    </insert>

    <select id="selectRecipe" parameterType="int" resultMap="recipes3ResultMap">
        SELECT
            r.RECIPE_ID,
            r.APPUSERID,
            r.TITLE,
            r.CATEGORY,
            r.IMAGE,
            r.COOK_TIME,
            r.DIFFICULTY,
            r.SERVINGS,
            r.DESCRIPTION,
            r.STATUS,
            r.CREATED_AT,
            r.UPDATED_AT,
            r.VIEWS,
            r.R_URL,
            c.CATEGORY_NAME,
            b.NICKNAME
        FROM recipes3 r
        LEFT JOIN CATEGORY3 c ON r.CATEGORY = c.CATEGORY
        LEFT JOIN BUG3 b ON r.APPUSERID = b.APPUSERID
        WHERE r.RECIPE_ID = #{recipeId}
    </select>

    <update id="incrementRecipeViews" parameterType="int">
        UPDATE recipes3
        SET VIEWS = VIEWS + 1
        WHERE RECIPE_ID = #{recipeId}
    </update>

    <update id="updateRecipe" parameterType="com.thejoa703.dto.Recipes3Dto">
        UPDATE recipes3
        SET
            TITLE = #{title},
            CATEGORY = #{category},
            COOK_TIME = #{cookTime},
            DIFFICULTY = #{difficulty},
            SERVINGS = #{servings},
            DESCRIPTION = #{description},
            STATUS = #{status},
            UPDATED_AT = SYSDATE
        WHERE RECIPE_ID = #{recipeId}
          AND APPUSERID = #{appUserId}
    </update>

    <delete id="deleteRecipe" parameterType="int">
        DELETE FROM recipes3
        WHERE RECIPE_ID = #{recipeId}
    </delete>

    <!-- ==================================================
         2️⃣ INGREDIENT
    ================================================== -->

    <insert id="insertIngredient" parameterType="com.thejoa703.dto.RecipesIngre3">
        INSERT INTO recipes_ingre3 (
            INGRE_MAP_ID,
            RECIPE_ID,
            INGRE_NAME,
            INGRE_NUM,
            INGRE_ORDER
        ) VALUES (
            seq_ingre3.NEXTVAL,
            #{recipeId},
            #{ingreName},
            #{ingreNum},
            0
        )
    </insert>

    <select id="selectRecipeIngredients" parameterType="int"
            resultType="com.thejoa703.dto.RecipesIngre3">
        SELECT
            RECIPE_ID,
            INGRE_NAME,
            INGRE_NUM
        FROM recipes_ingre3
        WHERE RECIPE_ID = #{recipeId}
        ORDER BY INGRE_MAP_ID
    </select>

    <delete id="deleteIngredients" parameterType="int">
        DELETE FROM recipes_ingre3
        WHERE RECIPE_ID = #{recipeId}
    </delete>

    <!-- ==================================================
         3️⃣ STEP
    ================================================== -->

    <insert id="insertStep" parameterType="com.thejoa703.dto.RecipesStep3">
        INSERT INTO recipes_step3 (
            STEP_MAP_ID,
            RECIPE_ID,
            STEP_DESC,
            STEP_IMAGE,
            STEP_ORDER
        ) VALUES (
            seq_step3.NEXTVAL,
            #{recipeId},
            #{stepDesc},
            #{stepImage},
            0
        )
    </insert>

    <select id="selectRecipeSteps" parameterType="int"
            resultType="com.thejoa703.dto.RecipesStep3">
        SELECT
            RECIPE_ID,
            STEP_DESC,
            STEP_IMAGE
        FROM recipes_step3
        WHERE RECIPE_ID = #{recipeId}
        ORDER BY STEP_MAP_ID
    </select>

    <delete id="deleteSteps" parameterType="int">
        DELETE FROM recipes_step3
        WHERE RECIPE_ID = #{recipeId}
    </delete>

    <!-- ==================================================
         4️⃣ SEARCH
    ================================================== -->

    <select id="searchBothCount" parameterType="map" resultType="int">
        SELECT COUNT(DISTINCT r.RECIPE_ID)
        FROM recipes3 r
        LEFT JOIN CATEGORY3 c ON r.CATEGORY = c.CATEGORY
        LEFT JOIN recipes_step3 s ON r.RECIPE_ID = s.RECIPE_ID
        <where>
            <if test="keyword != null and keyword != ''">
                (
                    r.TITLE LIKE #{keyword}
                    OR r.DESCRIPTION LIKE #{keyword}
                    OR s.STEP_DESC LIKE #{keyword}
                    OR c.CATEGORY_NAME LIKE #{keyword}
                )
            </if>
            <if test="category != null">
                AND r.CATEGORY = #{category}
            </if>
        </where>
    </select>

    <select id="searchBothPaging" parameterType="map" resultMap="recipes3ResultMap">
        SELECT *
        FROM (
            SELECT
                ROW_NUMBER() OVER (
                    ORDER BY r.CREATED_AT DESC
                ) AS rnum,
                r.RECIPE_ID,
                r.APPUSERID,
                r.TITLE,
                r.CATEGORY,
                r.IMAGE,
                r.COOK_TIME,
                r.DIFFICULTY,
                r.SERVINGS,
                r.DESCRIPTION,
                r.STATUS,
                r.CREATED_AT,
                r.UPDATED_AT,
                r.VIEWS,
                r.R_URL,
                c.CATEGORY_NAME,
                b.NICKNAME
            FROM recipes3 r
            LEFT JOIN CATEGORY3 c ON r.CATEGORY = c.CATEGORY
            LEFT JOIN BUG3 b ON r.APPUSERID = b.APPUSERID
            LEFT JOIN recipes_step3 s ON r.RECIPE_ID = s.RECIPE_ID
            <where>
                <if test="keyword != null and keyword != ''">
                    (
                        r.TITLE LIKE #{keyword}
                        OR r.DESCRIPTION LIKE #{keyword}
                        OR s.STEP_DESC LIKE #{keyword}
                        OR c.CATEGORY_NAME LIKE #{keyword}
                    )
                </if>
                <if test="category != null">
                    AND r.CATEGORY = #{category}
                </if>
            </where>
            GROUP BY
                r.RECIPE_ID, r.APPUSERID, r.TITLE, r.CATEGORY,
                r.IMAGE, r.COOK_TIME, r.DIFFICULTY, r.SERVINGS,
                r.DESCRIPTION, r.STATUS, r.CREATED_AT, r.UPDATED_AT,
                r.VIEWS, r.R_URL, c.CATEGORY_NAME, b.NICKNAME
        )
        WHERE rnum BETWEEN #{rStart} AND #{rEnd}
    </select>

    <!-- ==================================================
         5️⃣ LIKE
    ================================================== -->

    <insert id="insertRecipeLike" parameterType="com.thejoa703.dto.RecipeLikes3">
        INSERT INTO RECIPE_LIKES3 (APPUSERID, RECIPE_ID)
        VALUES (#{appUserId}, #{recipeId})
    </insert>

    <delete id="deleteRecipeLike" parameterType="map">
        DELETE FROM RECIPE_LIKES3
        WHERE APPUSERID = #{appUserId}
          AND RECIPE_ID = #{recipeId}
    </delete>

    <select id="existsRecipeLike" parameterType="map" resultType="int">
        SELECT COUNT(*)
        FROM RECIPE_LIKES3
        WHERE APPUSERID = #{appUserId}
          AND RECIPE_ID = #{recipeId}
    </select>

    <select id="countRecipeLikes" parameterType="int" resultType="int">
        SELECT COUNT(*)
        FROM RECIPE_LIKES3
        WHERE RECIPE_ID = #{recipeId}
    </select>

    <select id="selectMyLikedRecipes" parameterType="int" resultMap="recipes3ResultMap">
        SELECT
            r.RECIPE_ID,
            r.APPUSERID,
            r.TITLE,
            r.CATEGORY,
            r.IMAGE,
            r.COOK_TIME,
            r.DIFFICULTY,
            r.SERVINGS,
            r.DESCRIPTION,
            r.STATUS,
            r.CREATED_AT,
            r.UPDATED_AT,
            r.VIEWS,
            r.R_URL,
            c.CATEGORY_NAME,
            b.NICKNAME
        FROM RECIPE_LIKES3 l
        JOIN recipes3 r ON l.RECIPE_ID = r.RECIPE_ID
        LEFT JOIN CATEGORY3 c ON r.CATEGORY = c.CATEGORY
        LEFT JOIN BUG3 b ON r.APPUSERID = b.APPUSERID
        WHERE l.APPUSERID = #{appUserId}
        ORDER BY l.CREATED_AT DESC
    </select>

    <!-- ==================================================
         6️⃣ AI USAGE
    ================================================== -->

    <insert id="insertAiUsageHistory" parameterType="com.thejoa703.dto.AiUsageHistory3">
        <selectKey keyProperty="aiHistId" resultType="int" order="BEFORE">
            SELECT seq_ai_usage_history3.NEXTVAL FROM dual
        </selectKey>
        INSERT INTO AI_USAGE_HISTORY3 (
            AI_HIST_ID, APPUSERID, AI_ACTION, CREATED_AT
        ) VALUES (
            #{aiHistId}, #{appUserId}, #{aiAction}, SYSDATE
        )
    </insert>

    <select id="selectAiUsageByUser" parameterType="int"
            resultType="com.thejoa703.dto.AiUsageHistory3">
        SELECT *
        FROM AI_USAGE_HISTORY3
        WHERE APPUSERID = #{appUserId}
        ORDER BY CREATED_AT DESC
    </select>

    <select id="selectAllAiUsage"
            resultType="com.thejoa703.dto.AiUsageHistory3">
        SELECT *
        FROM AI_USAGE_HISTORY3
        ORDER BY CREATED_AT DESC
    </select>

    <!-- ==================================================
         7️⃣ BAD WORD
    ================================================== -->

    <select id="selectBadWords" resultType="com.thejoa703.dto.BadWords3">
        SELECT *
        FROM BAD_WORDS3
        ORDER BY WORD
    </select>

    <insert id="insertBadWord" parameterType="com.thejoa703.dto.BadWords3">
        <selectKey keyProperty="wordId" resultType="int" order="BEFORE">
            SELECT bad_words3_seq.NEXTVAL FROM dual
        </selectKey>
        INSERT INTO BAD_WORDS3 (WORD_ID, WORD)
        VALUES (#{wordId}, #{word})
    </insert>

    <delete id="deleteBadWord" parameterType="int">
        DELETE FROM BAD_WORDS3
        WHERE WORD_ID = #{wordId}
    </delete>

</mapper>
