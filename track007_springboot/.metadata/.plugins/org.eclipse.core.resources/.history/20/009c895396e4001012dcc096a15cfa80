	@Transactional
	@Override
	public void saveSearchHistory(Integer appUserId, String keyword) {
		if (keyword == null || keyword.isBlank())
			return;
		recipeDao.insertSearchHistory(Map.of("appUserId", appUserId, "keyword", keyword));
	}

