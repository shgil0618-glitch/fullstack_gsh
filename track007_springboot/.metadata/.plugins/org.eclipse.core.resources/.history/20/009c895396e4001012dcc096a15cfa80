	@Transactional
	@Override
	public void addBadWord(String word) {
		if (word == null || word.isBlank())
			return;
		if (recipeDao.existsBadWord(word) == 0) {
			recipeDao.insertBadWord(Map.of("word", word));
		}
	}

	@Transactional
	@Override
	public void deleteBadWordById(int wordId) {
