<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org"
	xmlns:layout="http://www.ultraq.net.nz/thymeleaf/layout"
	layout:decorate="~{fragments/layout}">
<!--    #1. layout 렌더링    -->
<head lang="ko">
<meta charset="UTF-8">
<title>Insert title here</title>
</head>
<body>
	<div layout:fragment="content">
		    <div    class="container    my-5" id="contents"> 
      <h3>CoolsSMS</h3>
         <label for="to">받는사람 :</label> 
         <input type="text" id="to" name="to"/>   <!-- 인증번호 받을사람 휴대폰 번호 -->
         <input type="button" id="send"  value="전송" title="인증문자전송" class="form-control" >  <!-- 문자보내는 전송버튼 -->
      
         <hr/>
         <hr/>
      
         <label for="userNum">인증번호 :</label> 
          <input type="text" id="userNum"   name="userNum">   <!-- 인증번호 입력창 -->
         <input type="button" id="enterBtn"  value="확인"  title="인증"  class="form-control">   <!-- 인증번호와 내가 입력창에 입력한 인증번호 비교하는 창 -->      
    </div>
		
	</div>

</body>
</html>
